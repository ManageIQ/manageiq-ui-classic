- if @edit
  = render :partial => "layouts/flash_msg"
  - disabled = @edit && @edit[:new][:userid] == "admin"
  #user_info
    %h3
      = _("User Information")
  = react('UserForm', {:id => (@edit[:user_id]), :data => @record.dup, :disabled => disabled})
- else
  = settings_users_summary(@record)
  = render :partial => "rbac_tag_box"
