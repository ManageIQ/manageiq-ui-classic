              class="cds--structured-list-tbody"
              role="rowgroup"
            >
              <div
                class="cds--structured-list-row not-clickable"
                role="row"
                tabindex="0"
                title=""
              >
                <div
                  class="cds--structured-list-td content_value array_item"
                  dir="auto"
                  role="cell"
                  title=""
                >
                  <div
                    class="content"
                  >
                    <div
                      class="expand wrap_text"
                    >
                      Value
                    </div>
                  </div>
                </div>
              </div>
              <div
                class="cds--structured-list-row not-clickable"
                role="row"
                tabindex="1"
                title=""
              >
                <div
                  class="cds--structured-list-td content_value array_item"
                  dir="auto"
                  role="cell"
                  title="code mirror"
                >
                  <div
                    class="react-codemirror2 miq-codemirror miq-structured-list-code-mirror"
                  >
                    <div
                      class="CodeMirror cm-s-eclipse"
                      translate="no"
                    >
                      <div
                        style="overflow: hidden; position: relative; width: 3px; height: 0px; top: 0px; left: 0px;"
                      >
                        <textarea
                          autocapitalize="off"
                          autocorrect="off"
                          spellcheck="false"
                          style="position: absolute; bottom: -1em; padding: 0px; width: 1000px; height: 1em; min-height: 1em; outline: none;"
                          tabindex="0"
                        />
                      </div>
                      <div
                        class="CodeMirror-vscrollbar"
                        cm-not-content="true"
                        style="display: block; bottom: 0px;"
                        tabindex="-1"
                      >
                        <div
                          style="min-width: 1px; height: 54px;"
                        />
                      </div>
                      <div
                        class="CodeMirror-hscrollbar"
                        cm-not-content="true"
                        style="display: block; right: 0px; left: 0px;"
                        tabindex="-1"
                      >
                        <div
                          style="height: 100%; min-height: 1px; width: 53px;"
                        />
                      </div>
                      <div
                        class="CodeMirror-scrollbar-filler"
                        cm-not-content="true"
                      />
                      <div
                        class="CodeMirror-gutter-filler"
                        cm-not-content="true"
                      />
                      <div
                        class="CodeMirror-scroll"
                        tabindex="-1"
                      >
                        <div
                          class="CodeMirror-sizer"
                          style="margin-left: 0px; min-width: 3px; padding-right: 0px; padding-bottom: 0px;"
                        >
                          <div
                            style="position: relative;"
                          >
                            <div
                              class="CodeMirror-lines"
                              role="presentation"
                            >
                              <div
                                role="presentation"
                                style="position: relative; outline: none;"
                              >
                                <div
                                  class="CodeMirror-measure"
                                />
                                <div
                                  class="CodeMirror-measure"
                                >
                                  <pre
                                    class="CodeMirror-line"
                                    role="presentation"
                                  >
                                    <span
                                      role="presentation"
                                      style="padding-right: .1px;"
                                    >
                                        end
                                    </span>
                                  </pre>
                                </div>
                                <div
                                  style="position: relative; z-index: 1;"
                                />
                                <div
                                  class="CodeMirror-cursors"
                                />
                                <div
                                  class="CodeMirror-code"
                                  role="presentation"
                                />
                              </div>
                            </div>
                          </div>
                        </div>
                        <div
                          style="position: absolute; height: 50px; width: 1px; border-bottom: 0px solid transparent;"
                        />
                        <div
                          class="CodeMirror-gutters"
                        >
                          <div
                            class="CodeMirror-gutter CodeMirror-linenumbers"
                            style="width: 1px;"
                          />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </li>
  </ul>
</div>
`;

