exports[`Chart Card component should render the empty card 1`] = `
<div>
  <div
    class="card-pf card-pf-aggregate-status card-pf-accented chart-card"
  >
    <h2
      class="card-title"
    >
      Pods
    </h2>
    <div
      class="card-pf-body"
    >
