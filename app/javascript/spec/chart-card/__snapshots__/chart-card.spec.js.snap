exports[`Chart Card component should render the loading card 1`] = `
<div>
  <div
    class="card-pf card-pf-aggregate-status card-pf-accented chart-card"
  >
    <h2
      class="card-title"
    >
      Pods
    </h2>
    <div
      class="card-pf-body"
    >
      <div
        aria-atomic="true"
        aria-live="assertive"
        class="export-spinner cds--loading cds--loading--small"
      >
        <svg
          aria-label="loading"
          class="cds--loading__svg"
          role="img"
          viewBox="0 0 100 100"
        >
          <title>
            loading
          </title>
          <circle
            class="cds--loading__background"
            cx="50%"
            cy="50%"
            r="42"
          />
          <circle
            class="cds--loading__stroke"
            cx="50%"
            cy="50%"
            r="42"
          />
        </svg>
      </div>
    </div>
  </div>
</div>
`;

