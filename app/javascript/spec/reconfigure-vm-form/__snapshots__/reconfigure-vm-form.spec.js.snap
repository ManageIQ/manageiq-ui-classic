exports[`Reconfigure VM form component should render reconfigure form and show cd rom connect form 1`] = `
<div>
  <form
    class="form-react reconfigure-form"
  >
    <div
      class="drive_form"
      name="BasicInformation"
    >
      <div>
        <h3>
          Connect CD/DVD Drives
        </h3>
      </div>
      <div
        class="cds--form-item cds--text-input-wrapper cds--text-input-wrapper--readonly"
      >
        <div
          class="cds--text-input__label-wrapper"
        >
          <label
            class="cds--label"
            dir="auto"
            for="name"
          >
            Name
          </label>
        </div>
        <div
          class="cds--text-input__field-outer-wrapper"
        >
          <div
            class="cds--text-input__field-wrapper"
          >
            <input
              class="cds--text-input"
              id="name"
              name="name"
              readonly=""
              type="text"
              value="CD/DVD drive 1"
            />
            
            <span
              aria-atomic="true"
              aria-live="assertive"
              class="cds--text-input__counter-alert"
              role="alert"
            />
          </div>
        </div>
      </div>
      <div
        class="cds--form-item"
      >
        <div
          class="cds--select"
        >
          <label
            class="cds--label"
            dir="auto"
            for="host_file"
          >
            <span
              aria-hidden="true"
              class="ddorg__carbon-component-mapper_is-required isRequired-0-2-3"
            >
              *
            </span>
            Host File
          </label>
          <div
            class="cds--select-input__wrapper"
          >
            <select
              class="cds--select-input"
              id="host_file"
              name="host_file"
              title="<Choose>"
            >
              <option
                class="cds--select-option"
                label="<Choose>"
                value=""
              >
                &lt;Choose&gt;
              </option>
              <option
                class="cds--select-option"
                label="host file test 1.iso"
                value="host file test 1.iso,18"
              >
                host file test 1.iso
              </option>
              <option
                class="cds--select-option"
                label="host file test 2.iso"
                value="host file test 2.iso,18"
              >
                host file test 2.iso
              </option>
              <option
                class="cds--select-option"
                label="host file test 3.iso"
                value="host file test 3.iso,18"
              >
                host file test 3.iso
              </option>
            </select>
            <svg
              aria-hidden="true"
              class="cds--select__arrow"
              fill="currentColor"
              focusable="false"
              height="16"
              preserveAspectRatio="xMidYMid meet"
              viewBox="0 0 16 16"
              width="16"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M8 11 3 6 3.7 5.3 8 9.6 12.3 5.3 13 6z"
              />
            </svg>
            
          </div>
        </div>
      </div>
    </div>
    <div
      class="cds--btn-set"
    >
      <button
        class="cds--btn cds--btn--primary cds--btn--disabled"
        disabled=""
        type="submit"
      >
        Save
      </button>
      <button
        class="cds--btn cds--btn--secondary cds--btn--disabled"
        disabled=""
        type="button"
      >
        Reset
      </button>
      <button
        class="cds--btn cds--btn--secondary"
        type="button"
      >
        Cancel
      </button>
    </div>
  </form>
</div>
`;

